# .streamlit/secrets.toml.example
#
# HOW TO USE ON STREAMLIT CLOUD:
#   1. Copy this file to .streamlit/secrets.toml  (never commit that file)
#   2. Paste your real API keys where shown below
#   3. On Streamlit Cloud: Settings → Secrets → paste the contents there
#
# HOW TO USE LOCALLY (alternative to typing keys in the sidebar):
#   Copy to .streamlit/secrets.toml and fill in your keys.
#   The app reads them automatically via st.secrets[].

[api_keys]
SERPAPI_KEY    = "your_serpapi_key_here"
ANTHROPIC_KEY  = "your_anthropic_key_here"
